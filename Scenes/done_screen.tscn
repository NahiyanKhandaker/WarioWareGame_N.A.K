[sub_resource type="GDScript" id="GDScript_ihae0"]
resource_name = "main"
script/source = "extends Node2D

@onready var liveText: RichTextLabel = $RemainingLives

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	
	liveText.text = \"Lives left: \" + str(Globe.lives)
"

[sub_resource type="GDScript" id="GDScript_1q1k2"]
resource_name = "reset"
script/source = "extends Button

func _on_pressed() -> void:
	
	Globe.minigames_done = 0 #track how many minigames done
	Globe.lives = 5 #track how many lives left, also effecting garlic appearing
	Globe.mario = true #tracks if user wants to use mario or luigi
	Globe.rollingBackground = true #stops whether background rolls or not
	Globe.flappy = true #tracks if user wants to use flappy bird or red
	Globe.botDifficulty = \"easy\" #sets difficulty of pong bot

	get_tree().change_scene_to_file(\"res://Scenes/level_scene.tscn\") # back to intermission
"

